{
	"name": "@constellationdev/mcp",
	"version": "2.0.0",
	"author": "ShiftinBits Inc",
	"description": "Your AI assistant's telescope to constellations of code knowledge - MCP server for intelligent, secure codebase exploration",
	"type": "module",
	"bin": {
		"mcp-constellation": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rimraf dist && tsup && node utils/postbuild.js",
		"watch": "tsc --watch",
		"start": "npm run build && node dist/index.js",
		"inspector": "npm run build && npx @modelcontextprotocol/inspector@latest node dist/index.js",
		"lint": "eslint",
		"lint:fix": "eslint --fix",
		"lint:errors": "eslint --quiet",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"test:ci": "jest --ci --coverage --maxWorkers=2",
		"prepare": "husky"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.22.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@eslint/compat": "^1",
		"@jest/globals": "^30.2.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^20.11.24",
		"eslint": "^9.38.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.4",
		"husky": "^9.1.7",
		"jest": "^30.2.0",
		"lint-staged": "^16.2.7",
		"prettier": "^3.6.2",
		"rimraf": "^6.0.1",
		"ts-jest": "^29.4.4",
		"tsup": "^8.5.0",
		"typescript": "^5.3.3"
	},
	"engines": {
		"node": ">=18.19.0"
	},
	"lint-staged": {
		"*.{ts,tsx}": [
			"eslint --fix --quiet",
			"prettier --write"
		],
		"*.{js,jsx,mjs}": [
			"eslint --fix --quiet",
			"prettier --write"
		],
		"*.{json,md,css}": [
			"prettier --write"
		]
	}
}
