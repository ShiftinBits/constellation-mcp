{
	"$schema": "https://static.modelcontextprotocol.io/schemas/2025-07-09/server.schema.json",
	"name": "com.shiftinbits/constellation",
	"description": "Code Intelligence Platform for AI Coding Assistants",
	"repository": {
		"url": "https://github.com/ShiftinBits/constellation-mcp",
		"source": "github",
		"id": "1058830668"
	},
	"version": "0.1.3",
	"packages": [
		{
			"registry_type": "npm",
			"registry_base_url": "https://registry.npmjs.org",
			"identifier": "@constellationdev/mcp",
			"version": "0.1.3",
			"transport": {
				"type": "stdio"
			},
			"environment_variables": [
				{
					"description": "Your Constellation access key",
					"is_required": true,
					"format": "string",
					"is_secret": true,
					"name": "CONSTELLATION_ACCESS_KEY"
				}
			]
		}
	]
}
