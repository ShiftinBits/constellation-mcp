{
	"$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
	"name": "com.shiftinbits/constellation",
	"description": "Code Intelligence Platform for AI Coding Agents",
	"repository": {
		"url": "https://github.com/ShiftinBits/constellation-mcp",
		"source": "github",
		"id": "1058830668"
	},
	"version": "0.3.0",
	"packages": [
		{
			"registryType": "npm",
			"registryBaseUrl": "https://registry.npmjs.org",
			"identifier": "@constellationdev/mcp",
			"version": "0.3.0",
			"transport": {
				"type": "stdio"
			},
			"environmentVariables": [
				{
					"description": "Your Constellation access key",
					"isRequired": true,
					"format": "string",
					"isSecret": true,
					"name": "CONSTELLATION_ACCESS_KEY"
				}
			]
		}
	]
}
